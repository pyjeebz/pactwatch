[133.073336, "o", "\u001b[31m│\u001b[0m\u001b[1m \u001b[0m\u001b[1;31m[X] \u001b[0m\u001b[1m      \u001b[0m\u001b[1m \u001b[0m\u001b[31m│\u001b[0m\u001b[36m \u001b[0m\u001b[36mGET /users/{id}/orders                               \u001b[0m\u001b[36m \u001b[0m\u001b[31m│\u001b[0m Removed endpoint: GET /users/{id}/orders                                                                    \u001b[31m│\u001b[0m\r\n\u001b[31m│\u001b[0m\u001b[1m \u001b[0m\u001b[1;31mBREAKING\u001b[0m\u001b[1m  \u001b[0m\u001b[1m \u001b[0m\u001b[31m│\u001b[0m\u001b[36m                                                       \u001b[0m\u001b[31m│\u001b[0m                                                                                                             \u001b[31m│\u001b[0m\r\n\u001b[31m├────────────┼───────────────────────────────────────────────────────┼─────────────────────────────────────────────────────────────────────────────────────────────────────────────┤\u001b[0m\r\n\u001b[31m│\u001b[0m\u001b[1m \u001b[0m\u001b[1;32m[+] SAFE\u001b[0m\u001b[1m  \u001b[0m\u001b[1m \u001b[0m\u001b[31m│\u001b[0m\u001b[36m \u001b[0m\u001b[36mGET /users/{id}                                      \u001b[0m\u001b[36m \u001b[0m\u001b[31m│\u001b[0m New response field 'avatar_url' added to GET /users/{id}                                                    \u001b[31m│\u001b[0m\r\n\u001b[31m├────────────┼───────────────────────────────────────────────────────┼─────────────────────────────────────────────────────────────────────────────────────────────────────────────┤\u001b[0m\r\n\u001b[31m│\u001b[0m\u001b[1m \u001b[0m\u001b[1;32m[+] SAFE\u001b[0m\u001b[1m  \u001b[0m\u001b[1m \u001b[0m\u001b[31m│\u001b[0m\u001b[36m \u001b[0m\u001b[36mGET /users/{id}                                      \u001b[0m\u001b[36m \u001b[0m\u001b[31m│\u001b[0m New enum values ['moderator'] added to field 'role' in GET /users/{id}                                      \u001b[31m│\u001b[0m\r\n\u001b[31m└────────────┴─────────────────────