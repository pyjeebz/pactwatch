[133.076687, "o", "\u001b[1m                                                                                   web-dashboard                                                                                    \u001b[0m\r\n\u001b[32m┏━━━━━━━━━━━━┳━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\u001b[0m\r\n\u001b[32m┃\u001b[0m\u001b[1m \u001b[0m\u001b[1mSeverity  \u001b[0m\u001b[1m \u001b[0m\u001b[32m┃\u001b[0m\u001b[1m \u001b[0m\u001b[1mPath                                                 \u001b[0m\u001b[1m \u001b[0m\u001b[32m┃\u001b[0m\u001b[1m \u001b[0m\u001b[1mChange                                                                                                     \u001b[0m\u001b[1m \u001b[0m\u001b[32m┃\u001b[0m\r\n\u001b[32m┡━━━━━━━━━━━━╇━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━╇━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┩\u001b[0m\r\n\u001b[32m│\u001b[0m\u001b[1m \u001b[0m\u001b[1;32m[+] SAFE\u001b[0m\u001b[1m  \u001b[0m\u001b[1m \u001b[0m\u001b[32m│\u001b[0m\u001b[36m \u001b[0m\u001b[36mGET /admin/settings                                  \u001b[0m\u001b[36m \u001b[0m\u001b[32m│\u001b[0m New response field 'language' added to GET /admin/settings                                                  \u001b[32m│\u001b[0m\r\n\u001b[32m├────────────┼───────────────────────────────────────────────────────┼─────────────────────────────────────────────────────────────────────────────────────────────────────────────┤\u001b[0m\r\n\u001b[32m│\u001b[0m\u001b[1m \u001b[0m\u001b[1;32m[+] SAFE\u001b[0m\u001b[1m  \u001b[0m\u001b[1m \u001b[0m\u001b[32m│\u001b[0m\u001b[36m \u001b[0m\u001b[36mGET /users                                           \u001b[0m\u001b[36m \u001b[0m\u001b[32m│\u001b[0m Description/summary changed on GET /users                                                                   \u001b[32m│\u001b[0m\r\n\u001b[32m├────────────┼───────────────────────────────────────────────────────┼─────────────────────────────────────────────────────────────────────────────────────────────────────────────┤\u001b[0m\r\n\u001b[32m│\u001b[0m\u001b[1m \u001b[0m\u001b[1;32m[+] SAFE\u001b[0m\u001b[1m  \u001b[0m\u001b[1m \u001b[0m\u001b[32m│\u001b[0m\u001b[36m \u001b[0m\u001b[36mGET /users/{id}                                      \u001b[0m\u001b[36m \u001b[0m\u001b[32m│\u001b[0m New response field 'avatar_url' added to GET /users/{id}                                                    \u001b[32m│\u001b[0m\r\n\u001b[32m├────────────┼───────────────────────────────────────────────────────┼────────────────────────────────────────────────────────────────────────────────────────────────────────────"]
